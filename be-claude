#!/bin/bash
set -euo pipefail

# Resolve the real location of this script, following symlinks (macOS + Linux)
_source="$0"
while [ -L "$_source" ]; do
    _dir="$(cd -P "$(dirname "$_source")" && pwd)"
    _source="$(readlink "$_source")"
    [[ "$_source" != /* ]] && _source="$_dir/$_source"
done
SCRIPT_DIR="$(cd -P "$(dirname "$_source")" && pwd)"
unset _source _dir

# Load config
source "$SCRIPT_DIR/.env"

full=$(pwd)
base=$CODE_PATH
if [[ "$full" == "$base"* ]]; then
    prep="cd $full; "
else
    prep=""
fi
iterm_opts=()
if [[ -n "${ITERM_SESSION_ID:-}" ]]; then
    iterm_opts=(-o "SendEnv=ITERM_SESSION_ID")
fi

if [[ "${USE_1PASSWORD_GH:-}" == "1" ]]; then
    gh_token="${GH_TOKEN:-$(op plugin run -- gh auth token)}"
else
    gh_token="${GH_TOKEN:-$(gh auth token)}"
fi

ssh -t -p "${SSH_PORT:-2222}" "${iterm_opts[@]}" localhost "$prep GH_TOKEN=$gh_token ~/.local/bin/claude ${CLAUDE_ARGS:-} $(printf '%q ' "$@")"
