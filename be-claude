#!/bin/bash
set -euo pipefail

# Resolve the real location of this script, following symlinks (macOS + Linux)
_source="$0"
while [ -L "$_source" ]; do
    _dir="$(cd -P "$(dirname "$_source")" && pwd)"
    _source="$(readlink "$_source")"
    [[ "$_source" != /* ]] && _source="$_dir/$_source"
done
SCRIPT_DIR="$(cd -P "$(dirname "$_source")" && pwd)"
unset _source _dir

# Load config
source "$SCRIPT_DIR/.env"

full=$(pwd)
base=$CODE_PATH
if [[ "$full" == "$base"* ]]; then
    prep="cd $full; "
else
    prep=""
fi
ssh -t -p "${SSH_PORT:-2222}" localhost "$prep GH_TOKEN=${GH_TOKEN:-$(op plugin run -- gh auth token)} ~/.local/bin/claude --dangerously-skip-permissions"
