# Path to your local code directory. This will be mounted into the container
# at the same path so file references are identical inside and outside Docker.
CODE_PATH=/Users/yourname/Documents/code

# Host port that maps to SSH inside the container (default: 2222)
# SSH_PORT=2222

# Project/container name — override to run multiple instances side by side
# COMPOSE_PROJECT_NAME=claude-dev

# SSH public keys to allow into the container (space-separated or newline-separated).
# Add one key per line within the double quotes.
SSH_AUTHORIZED_KEYS="ssh-rsa AAAA...your_key_here... user@host"

# Default arguments passed to claude when running be-claude.
# CLAUDE_ARGS="--dangerously-skip-permissions"

# Default arguments passed to codex when running be-codex.
# CODEX_ARGS="--full-auto"

# Codex sandbox mode (default: danger-full-access). Bubblewrap can't create
# namespaces inside Docker, so the sandboxed modes don't work without --privileged.
# Possible values: read-only, workspace-write, danger-full-access
# CODEX_SANDBOX=danger-full-access

# Environment variables to forward into the container (space-separated names).
# Since this file is sourced as bash, you can use command substitution to set values.
FORWARD_ENVS="GH_TOKEN"
GH_TOKEN=$(gh auth token)
# For 1Password: GH_TOKEN=$(op plugin run -- gh auth token)

# Use mosh instead of SSH for resilient connections. Requires mosh to be
# installed on the host. Disabled by default; set to true to enable.
# USE_MOSH=true

# Disable automatic Claude credential sync between macOS Keychain and
# ~/.claude/.credentials.json. Set to 1 if you manage credentials manually.
# CLAUDE_CREDENTIAL_SYNC=false

# Additional apt packages to install in the container.
# EXTRA_PACKAGES="postgresql-client redis-tools"
