#!/bin/bash
# sync-claude-credentials — Bidirectional sync of Claude OAuth credentials.
#
# On macOS: reads credentials from Keychain ("Claude Code-credentials") and
# outputs the access and refresh tokens to stdout for use as
# CLAUDE_CODE_OAUTH_TOKEN and CLAUDE_CODE_OAUTH_REFRESH_TOKEN.
# On other platforms: extracts tokens from ~/.claude/.credentials.json.
#
# This script is best-effort — sync failures never block the session.
#
# Usage:
#   sync-claude-credentials pre   # Outputs access token (line 1) and refresh token (line 2)
#   sync-claude-credentials post  # Reads container creds from stdin, syncs to Keychain

set -uo pipefail
# Note: no -e — sync failures must not kill be-claude

CREDS_FILE="$HOME/.claude/.credentials.json"
KEYCHAIN_SERVICE="Claude Code-credentials"

is_macos() {
    [ "$(uname -s)" = "Darwin" ]
}

# Parse credentials JSON, output: expiresAt accessToken refreshToken (space-separated)
parse_creds() {
    python3 -c "
import json, sys
try:
    d = json.loads(sys.argv[1])
    oauth = d.get('claudeAiOauth', {})
    print(oauth.get('expiresAt', 0), oauth.get('accessToken', ''), oauth.get('refreshToken', ''))
except Exception:
    print('0  ')
" "$1"
}

read_keychain() {
    security find-generic-password -w -s "$KEYCHAIN_SERVICE" 2>/dev/null
}

write_keychain() {
    local json="$1"
    security delete-generic-password -s "$KEYCHAIN_SERVICE" >/dev/null 2>&1 || true
    security add-generic-password -s "$KEYCHAIN_SERVICE" -a "$USER" -w "$json" >/dev/null 2>&1
}

read_file() {
    [ -f "$CREDS_FILE" ] && cat "$CREDS_FILE"
}

# Pre-sync: pick the best credentials and output access + refresh tokens to stdout.
sync_pre_macos() {
    local keychain_json file_json keychain_exp keychain_token keychain_refresh file_exp file_token file_refresh

    keychain_json="$(read_keychain 2>/dev/null)" || keychain_json=""
    file_json="$(read_file 2>/dev/null)" || file_json=""

    if [ -n "$keychain_json" ]; then
        read keychain_exp keychain_token keychain_refresh <<< "$(parse_creds "$keychain_json")"
    else
        keychain_exp=0; keychain_token=""; keychain_refresh=""
    fi
    if [ -n "$file_json" ]; then
        read file_exp file_token file_refresh <<< "$(parse_creds "$file_json")"
    else
        file_exp=0; file_token=""; file_refresh=""
    fi

    if [ "$keychain_exp" -gt "$file_exp" ] 2>/dev/null; then
        printf '%s\n%s' "$keychain_token" "$keychain_refresh"
        echo "Using newer credentials from Keychain." >&2
    elif [ -n "$file_token" ]; then
        printf '%s\n%s' "$file_token" "$file_refresh"
        if [ "$file_exp" -gt "$keychain_exp" ] 2>/dev/null; then
            write_keychain "$file_json" && echo "Synced newer credentials from file to Keychain." >&2
        fi
    else
        echo "Warning: No Claude credentials found in Keychain or $CREDS_FILE" >&2
        echo "Run 'claude' on the host or inside the container to log in." >&2
    fi
}

sync_pre_file() {
    local file_json file_exp file_token file_refresh
    file_json="$(read_file 2>/dev/null)" || file_json=""
    if [ -n "$file_json" ]; then
        read file_exp file_token file_refresh <<< "$(parse_creds "$file_json")"
        [ -n "$file_token" ] && printf '%s\n%s' "$file_token" "$file_refresh"
    else
        echo "Warning: No Claude credentials found at $CREDS_FILE" >&2
        echo "Run 'claude' on the host or inside the container to log in." >&2
    fi
}

# Post-sync: read credentials JSON from stdin, update Keychain if newer.
sync_post() {
    local container_json container_exp keychain_json keychain_exp

    container_json="$(cat)"
    [ -n "$container_json" ] || return 0

    read container_exp _ <<< "$(parse_creds "$container_json")"
    [ "$container_exp" -gt 0 ] 2>/dev/null || return 0

    keychain_json="$(read_keychain 2>/dev/null)" || keychain_json=""
    if [ -n "$keychain_json" ]; then
        read keychain_exp _ <<< "$(parse_creds "$keychain_json")"
    else
        keychain_exp=0
    fi

    if [ "$container_exp" -gt "$keychain_exp" ] 2>/dev/null; then
        write_keychain "$container_json" && echo "Synced refreshed credentials from container back to Keychain." >&2
    fi
}

case "${1:-}" in
    pre)
        if [ "${CLAUDE_CREDENTIAL_SYNC:-true}" = "false" ]; then
            :
        elif is_macos; then
            sync_pre_macos || true
        else
            sync_pre_file || true
        fi
        ;;
    post)
        if [ "${CLAUDE_CREDENTIAL_SYNC:-true}" != "false" ] && is_macos; then
            sync_post || true
        fi
        ;;
    *)
        echo "Usage: sync-claude-credentials pre|post" >&2
        exit 1
        ;;
esac
