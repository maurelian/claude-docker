#!/bin/bash
# sync-claude-credentials — Read Claude OAuth credentials for container use.
#
# On macOS: reads the full credentials JSON from Keychain ("Claude Code-credentials").
# On other platforms: reads from ~/.claude/.credentials.json.
# Outputs the full JSON to stdout so the caller can pass it to the container.
#
# This script is best-effort — sync failures never block the session.
#
# Usage:
#   sync-claude-credentials pre   # Outputs full credentials JSON to stdout

set -uo pipefail
# Note: no -e — sync failures must not kill be-claude

CREDS_FILE="$HOME/.claude/.credentials.json"
KEYCHAIN_SERVICE="Claude Code-credentials"

is_macos() {
    [ "$(uname -s)" = "Darwin" ]
}

# Parse credentials JSON, output: expiresAt accessToken refreshToken (space-separated)
parse_creds() {
    python3 -c "
import json, sys
try:
    d = json.loads(sys.argv[1])
    oauth = d.get('claudeAiOauth', {})
    print(oauth.get('expiresAt', 0), oauth.get('accessToken', ''), oauth.get('refreshToken', ''))
except Exception:
    print('0  ')
" "$1"
}

read_keychain() {
    security find-generic-password -w -s "$KEYCHAIN_SERVICE" 2>/dev/null
}

write_keychain() {
    local json="$1"
    security delete-generic-password -s "$KEYCHAIN_SERVICE" >/dev/null 2>&1 || true
    security add-generic-password -s "$KEYCHAIN_SERVICE" -a "$USER" -w "$json" >/dev/null 2>&1
}

read_file() {
    [ -f "$CREDS_FILE" ] && cat "$CREDS_FILE"
}

# Pre-sync: pick the best credentials and output the full JSON to stdout.
# This allows the caller to write it directly to .credentials.json so Claude Code
# sees native "claude.ai" auth (with account metadata) instead of bare tokens.
sync_pre_macos() {
    local keychain_json file_json keychain_exp file_exp

    keychain_json="$(read_keychain 2>/dev/null)" || keychain_json=""
    file_json="$(read_file 2>/dev/null)" || file_json=""

    if [ -n "$keychain_json" ]; then
        read keychain_exp _ _ <<< "$(parse_creds "$keychain_json")"
    else
        keychain_exp=0
    fi
    if [ -n "$file_json" ]; then
        read file_exp _ _ <<< "$(parse_creds "$file_json")"
    else
        file_exp=0
    fi

    if [ "$keychain_exp" -gt "$file_exp" ] 2>/dev/null; then
        printf '%s' "$keychain_json"
    elif [ -n "$file_json" ] && [ "$file_exp" -gt 0 ] 2>/dev/null; then
        printf '%s' "$file_json"
        if [ "$file_exp" -gt "$keychain_exp" ] 2>/dev/null; then
            write_keychain "$file_json" && echo "Synced newer credentials from file to Keychain." >&2
        fi
    else
        echo "Warning: No Claude credentials found in Keychain or $CREDS_FILE" >&2
        echo "Run 'claude' on the host or inside the container to log in." >&2
    fi
}

sync_pre_file() {
    local file_json file_exp
    file_json="$(read_file 2>/dev/null)" || file_json=""
    if [ -n "$file_json" ]; then
        read file_exp _ _ <<< "$(parse_creds "$file_json")"
        [ "$file_exp" -gt 0 ] 2>/dev/null && printf '%s' "$file_json"
    else
        echo "Warning: No Claude credentials found at $CREDS_FILE" >&2
        echo "Run 'claude' on the host or inside the container to log in." >&2
    fi
}

case "${1:-}" in
    pre)
        if [ "${CLAUDE_CREDENTIAL_SYNC:-true}" = "false" ]; then
            :
        elif is_macos; then
            sync_pre_macos || true
        else
            sync_pre_file || true
        fi
        ;;
    *)
        echo "Usage: sync-claude-credentials pre" >&2
        exit 1
        ;;
esac
